# Copie para scripts/config/homologacao.env (não versionar) e preencha.
# Usado por scripts/smoke-minimo.ps1

# CNPJ do emitente de teste (14 dígitos, sem pontuação)
SMOKE_CNPJ=12345678000199

# UF do emitente (2 letras)
SMOKE_UF=RS

# Arquivo .pfx em src/FiscalService.Api/certificados/ ou caminho relativo ao DiretorioCertificados
SMOKE_CERTIFICADO_PATH=empresa-homologacao.pfx

# Senha do certificado A1
SMOKE_CERTIFICADO_SENHA=troque_pela_senha_do_pfx

# API (opcional — padrão: http://localhost:${SERVICE_PORT})
# SMOKE_BASE_URL=http://localhost:5555

# NFC-e — preencha se for testar cupom (homologação SEFAZ)
# SMOKE_ID_CSC=1
# SMOKE_CSC=seu_csc_homologacao
