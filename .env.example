# ── FiscalService — Variáveis de Ambiente ────────────────────────────────────
# Copie este arquivo para .env e preencha os valores antes de executar.
# NUNCA versione o .env com valores reais.

# Chave de autenticação da API (header X-Api-Key)
API_KEY=troque_por_uma_chave_forte_e_aleatoria

# Opcional — rotação sem downtime: a chave antiga continua válida junto com API_KEY (mesclada em ApiKey no startup)
# API_KEY_PREVIOUS=chave_antiga_ainda_aceita

# Opcional — OpenTelemetry OTLP (métricas + traces). Exige endpoint absoluto.
# OpenTelemetry__Enabled=true
# OpenTelemetry__OtlpEndpoint=http://localhost:4317
# (ou só) OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Opção A — URL (Heroku, painéis, etc.): o app converte para connection string Npgsql.
# DATABASE_URL=postgres://usuario:senha@host:5432/nome_do_banco?sslmode=disable

# Opção B — senha simples (Docker Compose local): use DB_PASSWORD + DB_HOST/PORT/NAME/USER.
# Se DB_PASSWORD começar com postgres://, também é tratado como URL (legado).
DB_PASSWORD=troque_por_uma_senha_forte

# Opcional (dotnet run local): usados junto com DB_PASSWORD para montar a connection string
# No Docker Compose o host do Postgres é "db"; localmente costuma ser localhost.
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=fiscal_db
# DB_USER=fiscal_user

# Se o provedor te passa URL (postgres://...) ou host remoto, prefira a string Npgsql completa
# (isso IGNORA a montagem por DB_PASSWORD):
# Database__ConnectionString=Host=SEU_HOST;Port=5432;Database=fiscal;Username=postgres;Password=SUA_SENHA;SSL Mode=Disable

# Porta exposta pelo serviço (padrão: 5555)
SERVICE_PORT=5555

# Ambiente SEFAZ: Homologacao | Producao
FISCAL_AMBIENTE=Homologacao

# Timeout em segundos para chamadas ao WebService SEFAZ
FISCAL_TIMEOUT_WS=30

# Opcional: desativar sink de arquivo Serilog (só console). Útil sem volume em /app/logs.
# Serilog__File__Disabled=true
# Serilog__File__Path=/caminho/alternativo/fiscal-.log
