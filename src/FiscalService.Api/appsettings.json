{
  "ApiKey": "DEFINIR_VIA_ENV",
  "Fiscal": {
    "Ambiente": "Homologacao",
    "SalvarXmls": true,
    "DiretorioXmls": "/app/xmls",
    "DiretorioSchemas": "/app/schemas",
    "DiretorioCertificados": "/app/certificados",
    "TimeoutWs": 30
  },
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=fiscal_db;Username=fiscal_user;Password=DEFINIR_VIA_ENV"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/fiscal-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
