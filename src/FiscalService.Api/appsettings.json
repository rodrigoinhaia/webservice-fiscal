{
  "ApiKey": "DEFINIR_VIA_ENV",
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 180,
    "WindowSeconds": 60
  },
  "OpenTelemetry": {
    "Enabled": false,
    "OtlpEndpoint": ""
  },
  "Fiscal": {
    "Ambiente": "Homologacao",
    "SalvarXmls": true,
    "DiretorioXmls": "/app/xmls",
    "DiretorioSchemas": "/app/schemas",
    "DiretorioCertificados": "/app/certificados",
    "TimeoutWs": 30
  },
  "Database": {
    "ConnectionString": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "File": {
      "Path": "/app/logs/fiscal-.log",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 30,
      "Disabled": false
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
